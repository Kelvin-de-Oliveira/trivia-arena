# ═══════════════════════════════════════════════════════════════════════════
# .env.prod.ec2.example — Template de variáveis para deploy distribuído em EC2
# ═══════════════════════════════════════════════════════════════════════════
#
# Diferente do .env.prod.example original (pensado para rodar tudo num host
# só), este arquivo documenta as variáveis do deploy em 7 instâncias EC2
# separadas. CADA INSTÂNCIA USA APENAS A SEÇÃO CORRESPONDENTE A ELA — não
# copie o arquivo inteiro para nenhuma EC2, copie só a seção dela.
#
# Em cada instância, salve o conteúdo como ".env" (sem a parte "prod") na
# raiz do repositório clonado  esse nome exato é lido tanto pela diretiva
# env_file: .env (Gateway, GameService, UserService) quanto pela substituição
# automática de ${VAR} nos composes que não usam env_file (Shards,
# UserDB-Primary, UserDB-Replica, Kafka). Nenhuma flag extra é necessária.
#
# Substitua todo <IP_PRIVADO_EC2_*> pelo IP privado real de cada instância
# (EC2 Console → Instances → coluna "Private IPv4 address").
#
# ═══════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# EC2-Gateway
# ─────────────────────────────────────────────────────────────────────────────

# Gerado com: python3 -c "import secrets; print(secrets.token_hex(32))"
# Mesmo valor em EC2-Gateway, EC2-GameService-1, EC2-GameService-2 e EC2-UserService
JWT_SECRET=substitua-por-string-de-64-chars-gerada-aleatoriamente
JWT_EXPIRATION_SECONDS=86400

# Aponta para o Nginx local (mesma EC2), que balanceia entre as duas
# instâncias de Game Service — não usar o IP do GameService diretamente
GAME_GRPC_ADDRESS=nginx:9090

USER_GRPC_ADDRESS=<IP_PRIVADO_EC2_USERSERVICE>:9091

# IP elástico desta EC2-Gateway (fixo — não muda entre sessões do Lab)
# Usado em build-time pelo Vite para gerar o bundle do frontend
VITE_API_GATEWAY_HOST=<IP_ELASTICO_EC2_GATEWAY>:8000
CORS_ORIGINS=["http://<IP_ELASTICO_GATEWAY>"]

# ─────────────────────────────────────────────────────────────────────────────
# EC2-GameService-1 e EC2-GameService-2 — mesmo conteúdo nas duas instâncias
# ─────────────────────────────────────────────────────────────────────────────

JWT_SECRET=substitua-por-string-de-64-chars-gerada-aleatoriamente
JWT_EXPIRATION_SECONDS=86400

# Shard A e Shard B dividem a EC2-Shards — mesmo IP, portas diferentes
DB_SHARD_A_HOST=<IP_PRIVADO_EC2_SHARDS>
DB_SHARD_A_PORT=5432
DB_SHARD_A_NAME=questions_shard_a
DB_SHARD_A_USER=trivia
DB_SHARD_A_PASS=trivia

DB_SHARD_B_HOST=<IP_PRIVADO_EC2_SHARDS>
DB_SHARD_B_PORT=5433
DB_SHARD_B_NAME=questions_shard_b
DB_SHARD_B_USER=trivia
DB_SHARD_B_PASS=trivia

REDIS_HOST=<IP_PRIVADO_EC2_REDIS>
REDIS_PORT=6379

# Listener EXTERNAL da Kafka (porta 9092) — os outros listeners (29092) são
# só para uso interno entre os containers dentro da própria EC2-Kafka
KAFKA_BROKERS=<IP_PRIVADO_EC2_KAFKA>:9092

GAME_QUESTION_TIMEOUT_MS=30000
GAME_ROOM_TTL_SECONDS=3600


# ─────────────────────────────────────────────────────────────────────────────
# EC2-UserService
# ─────────────────────────────────────────────────────────────────────────────

JWT_SECRET=substitua-por-string-de-64-chars-gerada-aleatoriamente
JWT_EXPIRATION_SECONDS=86400

DB_USERDB_NAME=trivia_users
DB_USERDB_USER=trivia
DB_USERDB_PASS=trivia_pass

DB_USER_PRIMARY_HOST=<IP_PRIVADO_EC2_USERDB_PRIMARY>
DB_USER_PRIMARY_PORT=5432

DB_USER_REPLICA_HOST=<IP_PRIVADO_EC2_USERDB_REPLICA>
DB_USER_REPLICA_PORT=5432

KAFKA_BROKERS=<IP_PRIVADO_EC2_KAFKA>:9092


# ─────────────────────────────────────────────────────────────────────────────
# EC2-Kafka
# ─────────────────────────────────────────────────────────────────────────────

# IP privado desta própria EC2-Kafka (não o IP de quem acessa)
KAFKA_EXTERNAL_HOST=<IP_PRIVADO_DESTA_EC2_KAFKA>


# ─────────────────────────────────────────────────────────────────────────────
# EC2-UserDB-Primary e EC2-UserDB-Replica — mesmo conteúdo nas duas instâncias
# ─────────────────────────────────────────────────────────────────────────────

DB_USERDB_NAME=trivia_users
DB_USERDB_USER=trivia
DB_USERDB_PASS=trivia_pass


# ─────────────────────────────────────────────────────────────────────────────
# EC2-Shards (Shard A + Shard B na mesma instância)
# ─────────────────────────────────────────────────────────────────────────────

DB_SHARD_A_NAME=questions_shard_a
DB_SHARD_A_USER=trivia
DB_SHARD_A_PASS=trivia

DB_SHARD_B_NAME=questions_shard_b
DB_SHARD_B_USER=trivia
DB_SHARD_B_PASS=trivia


# ─────────────────────────────────────────────────────────────────────────────
# EC2-Redis
# ─────────────────────────────────────────────────────────────────────────────
#
# Nenhuma variável necessária — docker-compose.ec2-redis.yml não usa env_file
# nem ${VAR}. Não crie .env.prod nesta instância.



